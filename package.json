{
  "name": "floci-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json && echo '{\"type\":\"commonjs\"}' > dist/backend/package.json",
    "start": "node dist/backend/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run",
    "test:unit": "vitest run --exclude src/backend/integration.test.ts",
    "test:cov": "vitest run --coverage --exclude src/backend/integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.1068.0",
    "@aws-sdk/client-cloudwatch": "^3.1068.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1068.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-ec2": "^3.1068.0",
    "@aws-sdk/client-ecs": "^3.1070.0",
    "@aws-sdk/client-eventbridge": "^3.1068.0",
    "@aws-sdk/client-iam": "^3.1068.0",
    "@aws-sdk/client-kms": "^3.1068.0",
    "@aws-sdk/client-lambda": "^3.1068.0",
    "@aws-sdk/client-rds": "^3.1068.0",
    "@aws-sdk/client-route-53": "^3.1070.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.1068.0",
    "@aws-sdk/client-sns": "^3.1068.0",
    "@aws-sdk/client-sqs": "^3.1068.0",
    "@aws-sdk/client-ssm": "^3.1070.0",
    "@aws-sdk/util-dynamodb": "^3.996.4",
    "@cloudscape-design/collection-hooks": "^1.0.0",
    "@cloudscape-design/components": "^3.0.0",
    "@cloudscape-design/global-styles": "^1.0.0",
    "@hono/node-server": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "hono": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^9.0.0",
    "happy-dom": "^20.10.5",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
