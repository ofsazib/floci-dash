{
  "name": "floci-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json && echo '{\"type\":\"commonjs\"}' > dist/backend/package.json",
    "start": "node dist/backend/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run",
    "test:unit": "vitest run --exclude src/backend/integration.test.ts",
    "test:cov": "vitest run --coverage --exclude src/backend/integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1071.0",
    "@aws-sdk/client-api-gateway": "^3.1070.0",
    "@aws-sdk/client-apigatewayv2": "^3.1071.0",
    "@aws-sdk/client-appconfig": "^3.1072.0",
    "@aws-sdk/client-appconfigdata": "^3.1072.0",
    "@aws-sdk/client-appsync": "^3.1070.0",
    "@aws-sdk/client-athena": "^3.1072.0",
    "@aws-sdk/client-auto-scaling": "^3.1071.0",
    "@aws-sdk/client-backup": "^3.1072.0",
